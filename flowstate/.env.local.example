# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Lemon Squeezy (MoR)
LEMONSQUEEZY_API_KEY=your-api-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret
# Subscription variant IDs (two Subscription products: Pro Monthly + Pro Yearly)
LEMONSQUEEZY_VARIANT_MONTHLY=
LEMONSQUEEZY_VARIANT_YEARLY=

# Signed audio delivery (Cloudflare Worker `flowstate-audio-delivery`, see worker/)
# Leave empty in dev to play from local /public files.
NEXT_PUBLIC_AUDIO_WORKER_URL=https://flowstate-audio-delivery.<account>.workers.dev

# Legacy direct-CDN base (only used when the worker URL is empty)
NEXT_PUBLIC_AUDIO_CDN_BASE_URL=

# App
NEXT_PUBLIC_APP_URL=https://flow.virzyguns.com

# Observability (empty = disabled)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN= (source-map upload, optional)
