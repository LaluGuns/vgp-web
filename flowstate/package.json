{
  "name": "flowstate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test \"scripts/release/*.test.mjs\" && node scripts/i18n/check-parity.cjs",
    "predeploy": "npm run typecheck && npm run lint && npm test && npm run build",
    "worker:sync-catalog": "npx wrangler r2 object put flowstate-audio/tracks/catalog.json --file public/tracks/catalog.json --content-type application/json --remote --force --config worker/wrangler.toml",
    "worker:deploy": "npx wrangler deploy --config worker/wrangler.toml"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@sentry/nextjs": "^10.64.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hls.js": "^1.6.5",
    "lucide-react": "^0.575.0",
    "next": "^15.3.3",
    "posthog-js": "^1.398.2",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "three": "^0.185.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@emnapi/core": "^1.7.1",
    "@emnapi/runtime": "^1.7.1",
    "@eslint/eslintrc": "^3.3.6",
    "@types/node": "^22.15.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/three": "^0.185.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.5",
    "eslint-config-next": "^15.5.19",
    "ffmpeg-static": "^5.3.0",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
