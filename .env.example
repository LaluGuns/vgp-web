# ─────────────────────────────────────────────────────────────
# VGP Universe — Environment Variables
# Copy to .env.local for local dev, and set the SAME keys in
# Vercel → Project → Settings → Environment Variables for production.
# Missing keys cause runtime crashes (auth, DB, crons), not build errors,
# so they are easy to miss. Keep this list complete.
# ─────────────────────────────────────────────────────────────

# Database — Supabase Postgres. Use the Supavisor pooler connection string
# (host ends with .pooler.supabase.com) so serverless connection limits hold.
DATABASE_URL=postgres://USER:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Token signing (unsubscribe links + founder session cookie).
# Generate once with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING

# Founder dashboard login passcode.
FOUNDER_PASSCODE=CHANGE_ME_FOUNDER_PASSCODE

# Cron authorization — shared secret. The SAME value must be set on the
# Cloudflare Worker that triggers /api/cron/process-campaigns every 10 min.
# Generate once with: openssl rand -hex 32
CRON_SECRET=CHANGE_ME_LONG_RANDOM_STRING

# Hostinger SMTP
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=founder@virzyguns.com
SMTP_PASS=YOUR_PASSWORD_HERE

# Google PageSpeed Insights (optional — without a key the public API is
# heavily rate-limited and the dashboard falls back to cached metrics).
PAGESPEED_API_KEY=

# Flowstate product database (optional) — Supabase Postgres holding the
# flowstate_* tables. Powers the founder dashboard's Flowstate tab.
# Without it the tab shows an honest "not connected" state (no fake numbers).
# Use the Supavisor pooler connection string, same as DATABASE_URL.
FLOWSTATE_DATABASE_URL=

# Sentry (optional) — error counts on the founder dashboard's Flowstate tab.
# Create an auth token with scopes: event:read project:read.
# Without it the Errors panel shows an honest "not connected" state.
SENTRY_AUTH_TOKEN=
# Defaults: org virzy-guns-production, project flowstate. Override if needed.
# SENTRY_ORG=
# SENTRY_PROJECT_SLUG=

# PostHog (optional) — anonymous visitor counts on the Flowstate tab.
# Create a Personal API key with scope: query:read.
# Without it the Visitors panel shows an honest "not connected" state.
POSTHOG_PERSONAL_API_KEY=
# Defaults: project id 511095, host https://us.posthog.com. Override if needed.
# POSTHOG_PROJECT_ID=
# POSTHOG_QUERY_HOST=
